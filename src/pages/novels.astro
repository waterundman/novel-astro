---
import BaseLayout from '../layouts/BaseLayout.astro';
import { novels as allNovels, genres } from '../data/novels';

// 按状态分组
const ongoingNovels = allNovels.filter(n => n.status === '连载中');
const completedNovels = allNovels.filter(n => n.status === '已完结');
---

<BaseLayout title="全部作品 | 桕树地街">
  <div class="container">
    <header class="page-header">
      <div class="page-header-line"></div>
      <h1 class="page-title">ALL WORKS</h1>
      <p class="page-desc">共 {allNovels.length} 部作品</p>
    </header>

    <!-- Stats -->
    <div class="stats-bar">
      <div class="stat-item">
        <span class="stat-value">{ongoingNovels.length}</span>
        <span class="stat-label">连载中</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">{completedNovels.length}</span>
        <span class="stat-label">已完结</span>
      </div>
      <div class="stat-item">
        <span class="stat-value">{allNovels.reduce((sum, n) => sum + n.totalChapters, 0)}</span>
        <span class="stat-label">总章节</span>
      </div>
    </div>

    <!-- Ongoing Novels -->
    {ongoingNovels.length > 0 && (
      <section class="novel-section">
        <div class="section-header">
          <h2 class="section-title">连载中</h2>
          <div class="section-line"></div>
        </div>
        
        <div class="novel-grid">
          {ongoingNovels.map((novel, index) => (
            <a href={`/blog/novel/${novel.id}`} class="novel-card" style={`--delay: ${index * 0.08}s`}>
              <div class="novel-card-header">
                <span class="novel-genre">{novel.genre}</span>
                <span class="novel-status ongoing">{novel.status}</span>
              </div>
              <h3 class="novel-title">{novel.title}</h3>
              <p class="novel-intro">{novel.intro}</p>
              <div class="novel-meta">
                <span class="novel-author">{novel.authorName}</span>
                <span class="novel-chapters">{novel.totalChapters}章</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Completed Novels -->
    {completedNovels.length > 0 && (
      <section class="novel-section">
        <div class="section-header">
          <h2 class="section-title">已完结</h2>
          <div class="section-line"></div>
        </div>
        
        <div class="novel-grid">
          {completedNovels.map((novel, index) => (
            <a href={`/blog/novel/${novel.id}`} class="novel-card" style={`--delay: ${index * 0.08}s`}>
              <div class="novel-card-header">
                <span class="novel-genre">{novel.genre}</span>
                <span class="novel-status completed">{novel.status}</span>
              </div>
              <h3 class="novel-title">{novel.title}</h3>
              <p class="novel-intro">{novel.intro}</p>
              <div class="novel-meta">
                <span class="novel-author">{novel.authorName}</span>
                <span class="novel-chapters">{novel.totalChapters}章</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Genre Filter -->
    <section class="novel-section">
      <div class="section-header">
        <h2 class="section-title">按分类浏览</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="genre-grid">
        {genres.filter(g => g.count > 0).map(genre => (
          <a href={`/blog/genre/${genre.name}`} class="genre-card">
            <span class="genre-name">{genre.name}</span>
            <span class="genre-count">{genre.count}</span>
          </a>
        ))}
      </div>
    </section>

    <div class="back-section">
      <a href="/" class="back-link">← 返回首页</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }
  
  .page-header-line {
    width: 60px;
    height: 3px;
    background: var(--line);
    margin-bottom: 20px;
  }
  
  .page-title {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 8px;
    margin-bottom: 8px;
  }
  
  .page-desc {
    font-size: 0.95rem;
    color: var(--text-light);
    letter-spacing: 2px;
  }
  
  .stats-bar {
    display: flex;
    gap: 48px;
    margin-bottom: 48px;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text);
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-lighter);
    font-family: var(--font-mono);
  }
  
  .novel-section {
    margin-bottom: 48px;
  }
  
  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }
  
  .section-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 3px;
    white-space: nowrap;
  }
  
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    position: relative;
  }
  
  .section-line::after {
    content: '';
    position: absolute;
    right: 0;
    top: -2px;
    width: 8px;
    height: 4px;
    background: var(--line);
  }
  
  .novel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  
  .novel-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.25s;
    animation: fadeIn 0.5s ease-out var(--delay) both;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .novel-card:hover {
    border-color: var(--line);
    box-shadow: 4px 4px 0 var(--line);
    transform: translate(-2px, -2px);
  }
  
  .novel-card-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  
  .novel-genre {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 1px;
  }
  
  .novel-status {
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }
  
  .novel-status.ongoing {
    color: var(--success);
  }
  
  .novel-status.completed {
    color: var(--text-lighter);
  }
  
  .novel-title {
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 600;
  }
  
  .novel-intro {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 16px;
  }
  
  .novel-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-lighter);
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  
  .novel-author {
    font-family: var(--font-mono);
  }
  
  .genre-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
  }
  
  .genre-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .genre-card:hover {
    border-color: var(--line);
    transform: translateX(4px);
  }
  
  .genre-name {
    font-size: 0.95rem;
  }
  
  .genre-count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-lighter);
  }
  
  .back-section {
    margin-top: 48px;
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .back-link:hover {
    color: var(--text);
  }
  
  @media (max-width: 768px) {
    .stats-bar {
      flex-direction: column;
      gap: 16px;
      align-items: center;
    }
    
    .novel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
