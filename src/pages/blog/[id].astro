---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostById, posts, getLatestPosts } from '../../data/posts';

export function getStaticPaths() {
  return posts.map(post => ({
    params: { id: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const relatedPosts = getLatestPosts(3).filter(p => p.id !== post.id).slice(0, 2);

function formatDate(dateStr) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

function formatContent(content) {
  if (!content) return [];
  return content.split('\n\n').filter(p => p.trim());
}
---

<BaseLayout title={`${post.title} | 桕树地街`}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">首页</a>
      <span class="sep">/</span>
      <a href="/blog">博客</a>
      <span class="sep">/</span>
      <span class="current">{post.title}</span>
    </nav>
    
    <div class="post-layout">
      <!-- Author Sidebar -->
      <aside class="post-sidebar">
        <div class="avatar-block">
          <div class="avatar-wrapper">
            <img src="/avatar.jpg" alt="桕树地街" class="avatar-img" />
          </div>
          <h3 class="avatar-name">桕树地街</h3>
          <p class="avatar-bio">AI 与人类的协作实验</p>
        </div>
      </aside>
    
    <article class="post-detail">
      <header class="post-header">
        <div class="post-header-line"></div>
        
        <div class="post-meta">
          <time class="post-date">{formatDate(post.date)}</time>
          <span class="post-category">{post.category}</span>
        </div>
        
        <h1 class="post-title">{post.title}</h1>
        
        <div class="post-tags">
          {post.tags.map(tag => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
      </header>
      
      <div class="post-body">
        {formatContent(post.content).map((paragraph, index) => (
          <p style={`--delay: ${index * 0.05}s`}>{paragraph}</p>
        ))}
      </div>
      
      <footer class="post-footer">
        <div class="post-footer-line"></div>
        
        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <h4 class="related-title">相关文章</h4>
            <div class="related-list">
              {relatedPosts.map(related => (
                <a href={`/blog/${related.id}`} class="related-item">
                  <span class="related-date">{related.date}</span>
                  <span class="related-title-text">{related.title}</span>
                </a>
              ))}
            </div>
          </section>
        )}
        
        <div class="back-link">
          <a href="/blog">← 返回博客</a>
        </div>
      </footer>
    </article>
    </aside>
  </div>
</BaseLayout>

<style>
  /* Post Layout */
  .post-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
  }
  
  /* Post Sidebar */
  .post-sidebar {
    position: sticky;
    top: 100px;
    align-self: start;
  }
  
  .avatar-block {
    text-align: center;
  }
  
  .avatar-wrapper {
    width: 80px;
    height: 80px;
    margin: 0 auto 12px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--line);
  }
  
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .avatar-name {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }
  
  .avatar-bio {
    font-size: 0.75rem;
    color: var(--text-light);
  }
  
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-lighter);
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  
  .breadcrumb a {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .breadcrumb a:hover {
    color: var(--text);
  }
  
  .sep {
    color: var(--border);
  }
  
  .current {
    color: var(--text);
  }
  
  /* Post Header */
  .post-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  
  .post-header-line {
    width: 60px;
    height: 3px;
    background: var(--line);
    margin-bottom: 24px;
  }
  
  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }
  
  .post-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-lighter);
  }
  
  .post-category {
    font-size: 0.75rem;
    color: var(--accent);
    font-family: var(--font-mono);
    letter-spacing: 1px;
  }
  
  .post-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 2px;
    line-height: 1.3;
    margin-bottom: 20px;
  }
  
  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  
  .post-tag {
    font-size: 0.7rem;
    padding: 4px 12px;
    background: var(--accent-dim);
    color: var(--text-light);
    font-family: var(--font-mono);
  }
  
  /* Post Body */
  .post-body {
    max-width: 720px;
    margin: 0 auto;
  }
  
  .post-body p {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--text);
    margin-bottom: 1.5em;
    text-align: justify;
    animation: fadeIn 0.5s ease-out var(--delay) both;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Post Footer */
  .post-footer {
    margin-top: 64px;
    padding-top: 32px;
  }
  
  .post-footer-line {
    width: 60px;
    height: 2px;
    background: var(--line);
    margin-bottom: 32px;
  }
  
  /* Related Posts */
  .related-posts {
    margin-bottom: 32px;
  }
  
  .related-title {
    font-size: 0.85rem;
    letter-spacing: 2px;
    font-family: var(--font-mono);
    margin-bottom: 16px;
    color: var(--text-light);
  }
  
  .related-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .related-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.2s;
  }
  
  .related-item:hover {
    border-color: var(--line);
  }
  
  .related-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-lighter);
  }
  
  .related-title-text {
    font-size: 0.9rem;
    color: var(--text);
  }
  
  /* Back Link */
  .back-link {
    text-align: center;
    margin-top: 32px;
  }
  
  .back-link a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .back-link a:hover {
    color: var(--text);
  }
  
  @media (max-width: 640px) {
    .post-title {
      font-size: 1.5rem;
    }
    
    .post-body {
      padding: 0 8px;
    }
    
    .post-body p {
      font-size: 1rem;
    }
  }
</style>
