---
import BaseLayout from '../layouts/BaseLayout.astro';
import { novels as allNovels } from '../data/novels';
import { getLatestPosts } from '../data/posts';

// 基于日期生成随机种子，确保每天展示相同的小说
function getDailySeed() {
  const now = new Date();
  return now.getFullYear() * 10000 + (now.getMonth() + 1) * 100 + now.getDate();
}

// 伪随机数生成器
function seededRandom(seed) {
  let x = Math.sin(seed) * 10000;
  return x - Math.floor(x);
}

// 每天随机抽取6本小说
function getDailyNovels(novels, count = 6) {
  if (novels.length <= count) return novels;
  
  const seed = getDailySeed();
  const shuffled = [...novels];
  
  // Fisher-Yates shuffle with seed
  for (let i = shuffled.length - 1; i > 0; i--) {
    const random = seededRandom(seed + i);
    const j = Math.floor(random * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  
  return shuffled.slice(0, count);
}

const displayNovels = getDailyNovels(allNovels, 6);
const hiddenNovels = allNovels.length > 6;
const posts = getLatestPosts(3);
const currentYear = new Date().getFullYear();
const currentMonth = new Date().getMonth() + 1;

function formatDate(dateStr) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
}
---

<BaseLayout title="桕树地街">
  <div class="container">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-line"></div>
        <h1 class="hero-title">桕树地街</h1>
        <p class="hero-desc">个人作品的分享与展示</p>
        <div class="hero-meta">
          <span class="hero-stat">
            <strong>{posts.length}</strong> 篇博客
          </span>
          <span class="hero-stat">
            <strong>{allNovels.length}</strong> 部小说
          </span>
          <span class="hero-stat">
            <strong>{currentYear}.{currentMonth}</strong> 持续更新
          </span>
        </div>
      </div>
    </section>

    <!-- Novels -->
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">今日推荐</h2>
        <div class="section-line"></div>
        {hiddenNovels && (
          <a href="/novels" class="more-link">全部作品 →</a>
        )}
      </div>
      
      <div class="novel-list">
        {displayNovels.map((novel, index) => (
          <a href={`/blog/novel/${novel.id}`} class="novel-item" style={`--delay: ${index * 0.1}s`}>
            <div class="novel-content">
              <div class="novel-header">
                <h3 class="novel-title">{novel.title}</h3>
                <span class="novel-status">{novel.status}</span>
              </div>
              <p class="novel-intro">{novel.intro}</p>
              <div class="novel-meta">
                <span class="novel-author">作者：{novel.authorName}</span>
                <span class="novel-chapters">{novel.totalChapters} 章节</span>
                <span class="novel-genre">{novel.genre}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      
      {hiddenNovels && (
        <div class="novel-footer">
          <p class="novel-hint">共 {allNovels.length} 部作品，每日随机展示 6 部</p>
        </div>
      )}
    </section>

    <!-- Blog Posts -->
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">最新博客</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="blog-grid">
        {posts.map((post, index) => (
          <a href={`/blog/${post.id}`} class="blog-card" style={`--delay: ${index * 0.1}s`}>
            <div class="blog-card-header">
              <span class="blog-date">{formatDate(post.date)}</span>
              <span class="blog-category">{post.category}</span>
            </div>
            <h3 class="blog-title">{post.title}</h3>
            <p class="blog-excerpt">{post.excerpt}</p>
            <div class="blog-tags">
              {post.tags.slice(0, 2).map(tag => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
      
      <div class="more-link-wrapper">
        <a href="/blog">查看更多博客 →</a>
      </div>
    </section>
    
    <!-- About -->
    <section class="section about-section">
      <div class="about-content">
        <div class="about-line"></div>
        <h3>关于 桕树地街</h3>
        <p>这是我的博客平台，提交小说内容将由我完成开头，而后令ai定期更新，我很好奇这样究竟会发生怎样的化学反应。另外我会在这里更新自己的美术作品集，制作好用的skill也会分享于上面，喜欢的朋友可以多多关注我的网站</p>
        <div class="about-features">
          <div class="about-feature">
            <span class="feature-icon">⟡</span>
            <span>静态生成</span>
          </div>
          <div class="about-feature">
            <span class="feature-icon">∞</span>
            <span>AI驱动</span>
          </div>
          <div class="about-feature">
            <span class="feature-icon">⚡</span>
            <span>低功耗</span>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 80px 0;
    text-align: center;
    position: relative;
  }
  
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .hero-line {
    width: 2px;
    height: 60px;
    background: var(--line);
    margin-bottom: 32px;
  }
  
  .hero-title {
    font-family: var(--font-mono);
    font-size: 3.5rem;
    font-weight: bold;
    letter-spacing: 8px;
    line-height: 1.2;
    margin-bottom: 24px;
  }
  
  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-light);
    letter-spacing: 4px;
    margin-bottom: 40px;
  }
  
  .hero-meta {
    display: flex;
    gap: 48px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-lighter);
  }
  
  .hero-stat strong {
    color: var(--text);
    font-size: 1.2rem;
    display: block;
  }
  
  /* Section */
  .section {
    margin-bottom: 64px;
  }
  
  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }
  
  .section-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 3px;
    white-space: nowrap;
  }
  
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    position: relative;
  }
  
  .section-line::after {
    content: '';
    position: absolute;
    right: 0;
    top: -2px;
    width: 8px;
    height: 4px;
    background: var(--line);
  }
  
  .more-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .more-link:hover {
    color: var(--text);
  }
  
  /* Novel List */
  .novel-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  
  .novel-item {
    display: block;
    padding: 32px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
    animation: fadeIn 0.6s ease-out var(--delay) both;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .novel-item:hover {
    border-color: var(--line);
    box-shadow: 6px 6px 0 var(--line);
    transform: translate(-2px, -2px);
  }
  
  .novel-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .novel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  
  .novel-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }
  
  .novel-status {
    font-size: 0.75rem;
    padding: 4px 12px;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 12px;
    font-family: var(--font-mono);
    letter-spacing: 1px;
  }
  
  .novel-intro {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
    margin: 0;
  }
  
  .novel-meta {
    display: flex;
    gap: 16px;
    font-size: 0.85rem;
    color: var(--text-lighter);
    font-family: var(--font-mono);
  }
  
  .novel-author,
  .novel-chapters,
  .novel-genre {
    padding: 2px 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  
  .novel-footer {
    margin-top: 24px;
    text-align: center;
  }
  
  .novel-hint {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-lighter);
  }
  
  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }
  
  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.25s;
    animation: fadeIn 0.5s ease-out var(--delay) both;
  }
  
  .blog-card:hover {
    border-color: var(--line);
    box-shadow: 4px 4px 0 var(--line);
    transform: translate(-2px, -2px);
  }
  
  .blog-card-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  
  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-lighter);
  }
  
  .blog-category {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 1px;
  }
  
  .blog-title {
    font-size: 1.15rem;
    margin-bottom: 12px;
    font-weight: 600;
  }
  
  .blog-excerpt {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 16px;
  }
  
  .blog-tags {
    display: flex;
    gap: 8px;
  }
  
  .blog-tag {
    font-size: 0.7rem;
    padding: 2px 8px;
    background: var(--accent-dim);
    color: var(--text-light);
    font-family: var(--font-mono);
  }
  
  .more-link-wrapper {
    text-align: center;
    margin-top: 24px;
  }
  
  .more-link-wrapper a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .more-link-wrapper a:hover {
    color: var(--text);
  }
  
  /* About */
  .about-section {
    padding: 48px 0;
  }
  
  .about-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .about-line {
    width: 40px;
    height: 2px;
    background: var(--line);
    margin: 0 auto 24px;
  }
  
  .about-content h3 {
    font-family: var(--font-mono);
    letter-spacing: 4px;
    margin-bottom: 16px;
  }
  
  .about-content p {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 32px;
  }
  
  .about-features {
    display: flex;
    justify-content: center;
    gap: 48px;
  }
  
  .about-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-lighter);
  }
  
  .feature-icon {
    font-size: 1.5rem;
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2rem;
      letter-spacing: 4px;
    }
    
    .hero-meta {
      flex-direction: column;
      gap: 16px;
    }
    
    .novel-meta {
      flex-wrap: wrap;
      gap: 8px;
    }
    
    .novel-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
