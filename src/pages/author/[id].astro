---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { authors, novels } from '../../data/novels';

export function getStaticPaths() {
  return authors.map(author => ({
    params: { id: author.id },
    props: { author }
  }));
}

const { author } = Astro.props;
const authorNovels = novels.filter(n => n.authorId === author.id);
---

<BaseLayout title={`${author.name} | 桕树地街`}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">首页</a>
      <span class="sep">/</span>
      <span class="current">{author.name}</span>
    </nav>
    
    <header class="author-header">
      <div class="author-avatar-large">{author.avatar}</div>
      <div class="author-info">
        <h1 class="author-name">{author.name}</h1>
        <span class="author-type">{author.personality}</span>
        <p class="author-desc">{author.desc}</p>
        <div class="author-meta">
          <span class="meta-item">下次更新: {author.nextUpdate}</span>
          <span class="meta-item">{authorNovels.length} 部作品</span>
        </div>
      </div>
    </header>
    
    <section class="works-section">
      <div class="section-header">
        <h2 class="section-title">作品列表</h2>
        <div class="section-line"></div>
      </div>
      
      <div class="novel-grid">
        {authorNovels.map((novel, index) => (
          <a href={`/blog/novel/${novel.id}`} class="novel-card" style={`--delay: ${index * 0.1}s`}>
            <div class="novel-card-header">
              <span class="novel-genre">{novel.genre}</span>
              <span class="novel-status">{novel.status}</span>
            </div>
            <h3 class="novel-title">{novel.title}</h3>
            <p class="novel-intro">{novel.intro}</p>
            <div class="novel-meta">
              <span class="novel-chapters">{novel.totalChapters} 章节</span>
            </div>
          </a>
        ))}
      </div>
      
      {authorNovels.length === 0 && (
        <div class="empty-state">
          <div class="empty-icon">━</div>
          <p>该作者暂无作品</p>
        </div>
      )}
    </section>
    
    <div class="back-section">
      <a href="/" class="back-link">← 返回首页</a>
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-lighter);
    margin-bottom: 48px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  
  .breadcrumb a {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .breadcrumb a:hover { color: var(--text); }
  .sep { color: var(--border); }
  .current { color: var(--text); }
  
  .author-header {
    display: flex;
    gap: 32px;
    margin-bottom: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border);
  }
  
  .author-avatar-large {
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--line);
    color: var(--bg-card);
    font-family: var(--font-mono);
    font-size: 3rem;
    font-weight: bold;
    flex-shrink: 0;
  }
  
  .author-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .author-name {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 2px;
  }
  
  .author-type {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    letter-spacing: 1px;
  }
  
  .author-desc {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.8;
  }
  
  .author-meta {
    display: flex;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-lighter);
  }
  
  .works-section { margin-bottom: 48px; }
  
  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
  }
  
  .section-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 3px;
    white-space: nowrap;
  }
  
  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    position: relative;
  }
  
  .section-line::after {
    content: '';
    position: absolute;
    right: 0;
    top: -2px;
    width: 8px;
    height: 4px;
    background: var(--line);
  }
  
  .novel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }
  
  .novel-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all 0.25s;
    animation: fadeIn 0.5s ease-out var(--delay) both;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .novel-card:hover {
    border-color: var(--line);
    box-shadow: 4px 4px 0 var(--line);
    transform: translate(-2px, -2px);
  }
  
  .novel-card-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  
  .novel-genre {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 1px;
  }
  
  .novel-status {
    font-size: 0.75rem;
    color: var(--success);
  }
  
  .novel-title {
    font-size: 1.25rem;
    margin-bottom: 12px;
    font-weight: 600;
  }
  
  .novel-intro {
    font-size: 0.9rem;
    color: var(--text-light);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 16px;
  }
  
  .novel-meta {
    font-size: 0.8rem;
    color: var(--text-lighter);
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  
  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--text-lighter);
  }
  
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 16px;
    opacity: 0.3;
  }
  
  .back-section {
    margin-top: 48px;
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .back-link:hover { color: var(--text); }
  
  @media (max-width: 768px) {
    .author-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    
    .author-meta {
      justify-content: center;
    }
  }
</style>
