---
import BaseLayout from '../layouts/BaseLayout.astro';
import { posts } from '../data/posts';
import { novels } from '../data/novels';

const postCount = posts.length;
const novelCount = novels.length;
const totalChapters = novels.reduce((sum, n) => sum + n.totalChapters, 0);
---

<BaseLayout title="关于 | 桕树地街">
  <div class="container">
    <header class="page-header">
      <div class="page-header-line"></div>
      <h1 class="page-title">ABOUT</h1>
      <p class="page-desc">关于这个项目的一些信息</p>
    </header>
    
    <div class="about-layout">
      <!-- Intro -->
      <section class="about-section">
        <div class="section-header">
          <span class="section-num">01</span>
          <h2 class="section-title">项目介绍</h2>
        </div>
        
        <div class="about-content">
          <p>
            桕树地街 是一个实验性的 AI 小说与博客平台。在这个项目中，我尝试探索人类与 AI 在创作过程中的协作模式。
          </p>
          <p>
            这里的「创作」分为两部分：<br/>
            <strong>小说</strong>——由 AI 根据设定生成具体内容。<br/>
            <strong>博客</strong>——我提供想法和方向，AI 辅助完成文字。
          </p>
          <p>
            技术上，这个网站使用 <strong>Astro</strong> 构建，是一个纯静态站点。这意味着它：
          </p>
          <ul class="feature-list">
            <li>⚡ 加载速度极快</li>
            <li>🔒 安全性高（无服务器、无数据库）</li>
            <li>💰 托管成本为零</li>
            <li>🌍 可部署到全球 CDN</li>
          </ul>
        </div>
      </section>
      
      <!-- Stats -->
      <section class="about-section">
        <div class="section-header">
          <span class="section-num">02</span>
          <h2 class="section-title">数据统计</h2>
        </div>
        
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-value">{novelCount}</span>
            <span class="stat-label">小说作品</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">{totalChapters}</span>
            <span class="stat-label">章节总数</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">{postCount}</span>
            <span class="stat-label">博客文章</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">100%</span>
            <span class="stat-label">静态生成</span>
          </div>
        </div>
      </section>
      
      <!-- Tech Stack -->
      <section class="about-section">
        <div class="section-header">
          <span class="section-num">03</span>
          <h2 class="section-title">技术栈</h2>
        </div>
        
        <div class="tech-list">
          <div class="tech-item">
            <span class="tech-name">Astro</span>
            <span class="tech-desc">静态站点框架</span>
          </div>
          <div class="tech-item">
            <span class="tech-name">Vanilla CSS</span>
            <span class="tech-desc">无 CSS 框架依赖</span>
          </div>
          <div class="tech-item">
            <span class="tech-name">Static Data</span>
            <span class="tech-desc">纯静态数据存储</span>
          </div>
          <div class="tech-item">
            <span class="tech-name">Cloudflare Pages</span>
            <span class="tech-desc">全球 CDN 托管</span>
          </div>
        </div>
      </section>
      
      <!-- Contact -->
      <section class="about-section">
        <div class="section-header">
          <span class="section-num">04</span>
          <h2 class="section-title">联系方式</h2>
        </div>
        
        <div class="contact-content">
          <p>如果你对这个项目感兴趣，或者有任何建议，欢迎交流。</p>
          <div class="contact-links">
            <a href="https://github.com" target="_blank" class="contact-link">
              <span class="link-icon">⌘</span>
              <span class="link-text">GitHub</span>
            </a>
            <a href="mailto:hello@example.com" class="contact-link">
              <span class="link-icon">✉</span>
              <span class="link-text">Email</span>
            </a>
            <a href="/blog" class="contact-link">
              <span class="link-icon">✎</span>
              <span class="link-text">博客</span>
            </a>
          </div>
        </div>
      </section>
    </div>
    
    <!-- Back -->
    <div class="back-section">
      <a href="/" class="back-link">← 返回首页</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }
  
  .page-header-line {
    width: 60px;
    height: 3px;
    background: var(--line);
    margin-bottom: 20px;
  }
  
  .page-title {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 8px;
    margin-bottom: 8px;
  }
  
  .page-desc {
    font-size: 0.95rem;
    color: var(--text-light);
    letter-spacing: 2px;
  }
  
  /* About Sections */
  .about-layout {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  
  .about-section {
    padding: 32px;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }
  
  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  
  .section-num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 2px;
  }
  
  .section-title {
    font-size: 1.1rem;
    letter-spacing: 2px;
    font-family: var(--font-mono);
  }
  
  /* Content */
  .about-content {
    color: var(--text-light);
    line-height: 1.8;
  }
  
  .about-content p {
    margin-bottom: 16px;
  }
  
  .about-content strong {
    color: var(--text);
  }
  
  .feature-list {
    list-style: none;
    margin-top: 16px;
  }
  
  .feature-list li {
    padding: 8px 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  
  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  
  .stat-card {
    text-align: center;
    padding: 20px;
    border: 1px solid var(--border);
  }
  
  .stat-value {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--text);
    margin-bottom: 8px;
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-lighter);
    font-family: var(--font-mono);
  }
  
  /* Tech */
  .tech-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  
  .tech-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border: 1px solid var(--border);
    background: var(--bg);
  }
  
  .tech-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  
  .tech-desc {
    font-size: 0.8rem;
    color: var(--text-lighter);
  }
  
  /* Contact */
  .contact-content {
    color: var(--text-light);
    line-height: 1.8;
  }
  
  .contact-links {
    display: flex;
    gap: 16px;
    margin-top: 20px;
  }
  
  .contact-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  
  .contact-link:hover {
    border-color: var(--line);
    background: var(--bg-card);
  }
  
  .link-icon {
    font-size: 1rem;
  }
  
  /* Back */
  .back-section {
    margin-top: 48px;
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .back-link:hover {
    color: var(--text);
  }
  
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .tech-list {
      grid-template-columns: 1fr;
    }
    
    .contact-links {
      flex-direction: column;
    }
  }
</style>
